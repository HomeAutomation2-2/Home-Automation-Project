// =========================================================
// HOME AUTOMATION SYSTEM — Prisma Schema
// Provider: PostgreSQL
// =========================================================

generator client {
  provider = "prisma-client"
  output   = "../../WEBSERVRS/backend/src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// =========================================================
// 1. ROLES
// =========================================================
model Role {
  role_id     BigInt  @id @default(autoincrement())
  role_code   String  @db.VarChar(30)
  role_name   String  @db.VarChar(100)
  description String?

  users User[]

  @@unique([role_code], name: "UQ_roles_role_code")
  @@map("roles")
}

// =========================================================
// 2. HOMES
// =========================================================
model Home {
  home_id      BigInt   @id @default(autoincrement())
  home_name    String   @db.VarChar(150)
  address_line String?  @db.VarChar(255)
  is_active    Boolean  @default(true)
  created_at   DateTime @default(now()) @db.Timestamptz()
  updated_at   DateTime @default(now()) @updatedAt @db.Timestamptz()

  users             User[]
  devices           Device[]
  rooms             Room[]
  access_points     AccessPoint[]
  boiler_controller BoilerController?

  @@map("homes")
}

// =========================================================
// 3. USERS
// =========================================================
model User {
  user_id           BigInt    @id @default(autoincrement())
  role_id           BigInt
  home_id           BigInt
  first_name        String    @db.VarChar(100)
  last_name         String    @db.VarChar(100)
  phone_number      String    @db.VarChar(20)
  phone_verified_at DateTime? @db.Timestamptz()
  cnp               String    @db.VarChar(13)
  password_hash     String    @db.VarChar(255)
  is_active         Boolean   @default(true)
  created_at        DateTime  @default(now()) @db.Timestamptz()
  updated_at        DateTime  @default(now()) @updatedAt @db.Timestamptz()

  role Role @relation(fields: [role_id], references: [role_id])
  home Home @relation(fields: [home_id], references: [home_id])

  auth_sessions     AuthSession[]
  user_devices      UserDevice[]
  access_events     AccessEvent[]
  presence_status   PresenceStatus?
  light_commands    LightCommand[]
  heating_overrides HeatingOverride[]
  light_events      LightEvent[]

  @@unique([phone_number], name: "UQ_users_phone_number")
  @@unique([cnp], name: "UQ_users_cnp")
  @@index([home_id], name: "IX_users_home_id")
  @@map("users")
}

// =========================================================
// 4. AUTH SESSIONS
// =========================================================
model AuthSession {
  session_id         BigInt    @id @default(autoincrement())
  user_id            BigInt
  access_token_hash  String    @db.VarChar(255)
  refresh_token_hash String?   @db.VarChar(255)
  client_type        String    @db.VarChar(20)
  ip_address         String?   @db.VarChar(64)
  user_agent         String?   @db.VarChar(500)
  issued_at          DateTime  @default(now()) @db.Timestamptz()
  expires_at         DateTime  @db.Timestamptz()
  revoked_at         DateTime? @db.Timestamptz()

  user User @relation(fields: [user_id], references: [user_id])

  @@index([user_id], name: "IX_auth_sessions_user_id")
  @@map("auth_sessions")
}

// =========================================================
// 5. DEVICES
// =========================================================
model Device {
  device_id        BigInt    @id @default(autoincrement())
  home_id          BigInt
  device_type      String    @db.VarChar(30)
  serial_no        String?   @db.VarChar(100)
  mac_address      String?   @db.VarChar(50)
  firmware_version String?   @db.VarChar(50)
  device_name      String?   @db.VarChar(150)
  last_seen_at     DateTime? @db.Timestamptz()
  is_active        Boolean   @default(true)
  created_at       DateTime  @default(now()) @db.Timestamptz()
  updated_at       DateTime  @default(now()) @updatedAt @db.Timestamptz()

  home Home @relation(fields: [home_id], references: [home_id])

  user_devices             UserDevice[]
  room_devices             RoomDevice[]
  access_events_as_device  AccessEvent[]        @relation("AccessEventDevice")
  access_points_esp32      AccessPoint[]        @relation("AccessPointEsp32")
  access_points_lock       AccessPoint[]        @relation("AccessPointLock")
  light_zones              LightZone[]
  light_events             LightEvent[]
  heating_loops_temp       HeatingLoop[]        @relation("HeatingLoopTempSensor")
  heating_loops_valve      HeatingLoop[]        @relation("HeatingLoopValve")
  temperature_readings     TemperatureReading[]
  valve_events             ValveEvent[]
  boiler_controllers       BoilerController[]
  device_status_logs       DeviceStatusLog[]

  @@unique([serial_no], name: "UQ_devices_serial_no")
  @@unique([mac_address], name: "UQ_devices_mac_address")
  @@index([home_id], name: "IX_devices_home_id")
  @@map("devices")
}

// =========================================================
// 6. USER DEVICES
// =========================================================
model UserDevice {
  user_device_id              BigInt    @id @default(autoincrement())
  user_id                     BigInt
  device_id                   BigInt
  bluetooth_security_code_hash String   @db.VarChar(255)
  puk_code_hash               String    @db.VarChar(255)
  is_primary                  Boolean   @default(true)
  is_active                   Boolean   @default(true)
  bound_at                    DateTime  @default(now()) @db.Timestamptz()
  unbound_at                  DateTime? @db.Timestamptz()

  user   User   @relation(fields: [user_id], references: [user_id])
  device Device @relation(fields: [device_id], references: [device_id])

  @@unique([user_id, device_id], name: "UQ_user_devices_user_device")
  @@map("user_devices")
}

// =========================================================
// 7. ROOMS
// =========================================================
model Room {
  room_id    BigInt   @id @default(autoincrement())
  home_id    BigInt
  room_name  String   @db.VarChar(100)
  room_type  String?  @db.VarChar(50)
  floor_no   Int?
  is_active  Boolean  @default(true)
  created_at DateTime @default(now()) @db.Timestamptz()
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz()

  home Home @relation(fields: [home_id], references: [home_id])

  room_devices  RoomDevice[]
  light_zones   LightZone[]
  heating_loops HeatingLoop[]

  @@unique([home_id, room_name], name: "UQ_rooms_home_room_name")
  @@map("rooms")
}

// =========================================================
// 8. ROOM DEVICES
// =========================================================
model RoomDevice {
  room_device_id BigInt   @id @default(autoincrement())
  room_id        BigInt
  device_id      BigInt
  device_role    String   @db.VarChar(30)
  installed_at   DateTime @default(now()) @db.Timestamptz()
  is_active      Boolean  @default(true)

  room   Room   @relation(fields: [room_id], references: [room_id])
  device Device @relation(fields: [device_id], references: [device_id])

  @@unique([room_id, device_id], name: "UQ_room_devices_room_device")
  @@index([room_id], name: "IX_room_devices_room_id")
  @@index([device_id], name: "IX_room_devices_device_id")
  @@map("room_devices")
}

// =========================================================
// 9. ACCESS POINTS
// =========================================================
model AccessPoint {
  access_point_id      BigInt   @id @default(autoincrement())
  home_id              BigInt
  esp32_device_id      BigInt
  lock_device_id       BigInt?
  access_point_name    String   @db.VarChar(100)
  location_description String?  @db.VarChar(255)
  is_active            Boolean  @default(true)
  created_at           DateTime @default(now()) @db.Timestamptz()
  updated_at           DateTime @default(now()) @updatedAt @db.Timestamptz()

  home         Home    @relation(fields: [home_id], references: [home_id])
  esp32_device Device  @relation("AccessPointEsp32", fields: [esp32_device_id], references: [device_id])
  lock_device  Device? @relation("AccessPointLock", fields: [lock_device_id], references: [device_id])

  access_events AccessEvent[]

  @@unique([home_id, access_point_name], name: "UQ_access_points_home_name")
  @@map("access_points")
}

// =========================================================
// 10. ACCESS EVENTS
// =========================================================
model AccessEvent {
  access_event_id BigInt    @id @default(autoincrement())
  access_point_id BigInt
  user_id         BigInt?
  device_id       BigInt?
  direction       String    @db.VarChar(10)
  result          String    @db.VarChar(15)
  event_time      DateTime  @default(now()) @db.Timestamptz()
  source          String    @default("BLUETOOTH") @db.VarChar(20)
  local_event_id  String?   @db.VarChar(100)
  synced_at       DateTime? @db.Timestamptz()
  failure_reason  String?   @db.VarChar(255)
  created_at      DateTime  @default(now()) @db.Timestamptz()

  access_point AccessPoint @relation(fields: [access_point_id], references: [access_point_id])
  user         User?       @relation(fields: [user_id], references: [user_id])
  device       Device?     @relation("AccessEventDevice", fields: [device_id], references: [device_id])

  presence_status PresenceStatus[]

  @@index([event_time(sort: Desc)], name: "IX_access_events_event_time")
  @@index([user_id, event_time(sort: Desc)], name: "IX_access_events_user_event_time")
  @@map("access_events")
}

// =========================================================
// 11. PRESENCE STATUS
// =========================================================
model PresenceStatus {
  user_id              BigInt    @id
  is_home              Boolean   @default(false)
  last_entry_at        DateTime? @db.Timestamptz()
  last_exit_at         DateTime? @db.Timestamptz()
  last_access_event_id BigInt?
  updated_at           DateTime  @default(now()) @updatedAt @db.Timestamptz()

  user              User         @relation(fields: [user_id], references: [user_id])
  last_access_event AccessEvent? @relation(fields: [last_access_event_id], references: [access_event_id])

  @@map("presence_status")
}

// =========================================================
// 12. LIGHT ZONES
// =========================================================
model LightZone {
  light_zone_id    BigInt   @id @default(autoincrement())
  room_id          BigInt
  relay_device_id  BigInt
  zone_name        String   @db.VarChar(100)
  relay_channel_no Int
  is_active        Boolean  @default(true)
  created_at       DateTime @default(now()) @db.Timestamptz()
  updated_at       DateTime @default(now()) @updatedAt @db.Timestamptz()

  room         Room   @relation(fields: [room_id], references: [room_id])
  relay_device Device @relation(fields: [relay_device_id], references: [device_id])

  light_commands LightCommand[]
  light_events   LightEvent[]

  @@unique([room_id, zone_name], name: "UQ_light_zones_room_name")
  @@unique([relay_device_id, relay_channel_no], name: "UQ_light_zones_device_channel")
  @@map("light_zones")
}

// =========================================================
// 13. LIGHT COMMANDS
// =========================================================
model LightCommand {
  light_command_id     BigInt    @id @default(autoincrement())
  light_zone_id        BigInt
  requested_by_user_id BigInt
  command_type         String    @db.VarChar(10)
  request_channel      String    @db.VarChar(20)
  requested_at         DateTime  @default(now()) @db.Timestamptz()
  status               String    @default("PENDING") @db.VarChar(15)
  executed_at          DateTime? @db.Timestamptz()
  failure_reason       String?   @db.VarChar(255)

  light_zone         LightZone    @relation(fields: [light_zone_id], references: [light_zone_id])
  requested_by_user  User         @relation(fields: [requested_by_user_id], references: [user_id])

  light_events LightEvent[]

  @@index([light_zone_id, requested_at(sort: Desc)], name: "IX_light_commands_zone_requested_at")
  @@map("light_commands")
}

// =========================================================
// 14. LIGHT EVENTS
// =========================================================
model LightEvent {
  light_event_id       BigInt   @id @default(autoincrement())
  light_zone_id        BigInt
  command_id           BigInt?
  event_type           String   @db.VarChar(15)
  event_time           DateTime @default(now()) @db.Timestamptz()
  source_device_id     BigInt?
  triggered_by_user_id BigInt?
  created_at           DateTime @default(now()) @db.Timestamptz()

  light_zone        LightZone     @relation(fields: [light_zone_id], references: [light_zone_id])
  light_command     LightCommand? @relation(fields: [command_id], references: [light_command_id])
  source_device     Device?       @relation(fields: [source_device_id], references: [device_id])
  triggered_by_user User?         @relation(fields: [triggered_by_user_id], references: [user_id])

  @@index([light_zone_id, event_time(sort: Desc)], name: "IX_light_events_zone_event_time")
  @@map("light_events")
}

// =========================================================
// 15. HEATING LOOPS
// =========================================================
model HeatingLoop {
  heating_loop_id          BigInt   @id @default(autoincrement())
  room_id                  BigInt
  temp_sensor_device_id    BigInt
  valve_device_id          BigInt
  loop_name                String   @db.VarChar(100)
  default_sampling_minutes Int      @default(5)
  is_active                Boolean  @default(true)
  created_at               DateTime @default(now()) @db.Timestamptz()
  updated_at               DateTime @default(now()) @updatedAt @db.Timestamptz()

  room              Room   @relation(fields: [room_id], references: [room_id])
  temp_sensor_device Device @relation("HeatingLoopTempSensor", fields: [temp_sensor_device_id], references: [device_id])
  valve_device      Device @relation("HeatingLoopValve", fields: [valve_device_id], references: [device_id])

  heating_profiles     HeatingProfile[]
  heating_overrides    HeatingOverride[]
  temperature_readings TemperatureReading[]
  heating_demands      HeatingDemand[]
  valve_events         ValveEvent[]
  boiler_events        BoilerEvent[]

  @@unique([room_id, loop_name], name: "UQ_heating_loops_room_name")
  @@unique([temp_sensor_device_id], name: "UQ_heating_loops_temp_sensor")
  @@unique([valve_device_id], name: "UQ_heating_loops_valve_device")
  @@map("heating_loops")
}

// =========================================================
// 16. HEATING PROFILES
// =========================================================
model HeatingProfile {
  heating_profile_id BigInt   @id @default(autoincrement())
  heating_loop_id    BigInt
  profile_name       String   @db.VarChar(100)
  profile_type       String   @db.VarChar(20)
  is_default         Boolean  @default(false)
  is_active          Boolean  @default(true)
  created_at         DateTime @default(now()) @db.Timestamptz()
  updated_at         DateTime @default(now()) @updatedAt @db.Timestamptz()

  heating_loop HeatingLoop @relation(fields: [heating_loop_id], references: [heating_loop_id])

  schedule_entries  HeatingScheduleEntry[]
  heating_overrides HeatingOverride[]

  @@unique([heating_loop_id, profile_name], name: "UQ_heating_profiles_loop_name")
  @@map("heating_profiles")
}

// =========================================================
// 17. HEATING SCHEDULE ENTRIES
// =========================================================
model HeatingScheduleEntry {
  schedule_entry_id  BigInt   @id @default(autoincrement())
  heating_profile_id BigInt
  day_type           String   @db.VarChar(20)
  sequence_no        Int
  start_time         DateTime @db.Time()
  end_time           DateTime @db.Time()
  target_temperature Decimal  @db.Decimal(5, 2)
  hysteresis         Decimal  @db.Decimal(5, 2)
  temp_offset        Decimal  @default(0.00) @db.Decimal(5, 2)
  created_at         DateTime @default(now()) @db.Timestamptz()
  updated_at         DateTime @default(now()) @updatedAt @db.Timestamptz()

  heating_profile HeatingProfile @relation(fields: [heating_profile_id], references: [heating_profile_id])

  @@unique([heating_profile_id, day_type, sequence_no], name: "UQ_heating_schedule_entries_profile_day_seq")
  @@map("heating_schedule_entries")
}

// =========================================================
// 18. HEATING OVERRIDES
// =========================================================
model HeatingOverride {
  heating_override_id  BigInt    @id @default(autoincrement())
  heating_loop_id      BigInt
  requested_by_user_id BigInt
  override_type        String    @db.VarChar(20)
  target_profile_id    BigInt?
  target_temperature   Decimal?  @db.Decimal(5, 2)
  start_at             DateTime  @db.Timestamptz()
  end_at               DateTime  @db.Timestamptz()
  is_active            Boolean   @default(true)
  created_at           DateTime  @default(now()) @db.Timestamptz()
  updated_at           DateTime  @default(now()) @updatedAt @db.Timestamptz()

  heating_loop       HeatingLoop     @relation(fields: [heating_loop_id], references: [heating_loop_id])
  requested_by_user  User            @relation(fields: [requested_by_user_id], references: [user_id])
  target_profile     HeatingProfile? @relation(fields: [target_profile_id], references: [heating_profile_id])

  @@map("heating_overrides")
}

// =========================================================
// 19. TEMPERATURE READINGS
// =========================================================
model TemperatureReading {
  temperature_reading_id BigInt   @id @default(autoincrement())
  heating_loop_id        BigInt
  device_id              BigInt
  temperature_c          Decimal  @db.Decimal(5, 2)
  sampled_at             DateTime @db.Timestamptz()
  sampling_minutes       Int
  received_at            DateTime @default(now()) @db.Timestamptz()
  quality_flag           String   @default("OK") @db.VarChar(20)

  heating_loop HeatingLoop @relation(fields: [heating_loop_id], references: [heating_loop_id])
  device       Device      @relation(fields: [device_id], references: [device_id])

  heating_demands HeatingDemand[]

  @@index([heating_loop_id, sampled_at(sort: Desc)], name: "IX_temperature_readings_loop_sampled_at")
  @@map("temperature_readings")
}

// =========================================================
// 20. HEATING DEMANDS
// =========================================================
model HeatingDemand {
  heating_demand_id      BigInt   @id @default(autoincrement())
  heating_loop_id        BigInt
  temperature_reading_id BigInt
  target_temperature     Decimal  @db.Decimal(5, 2)
  hysteresis             Decimal  @db.Decimal(5, 2)
  temp_offset            Decimal  @default(0.00) @db.Decimal(5, 2)
  demand_state           String   @db.VarChar(20)
  evaluated_at           DateTime @default(now()) @db.Timestamptz()

  heating_loop         HeatingLoop        @relation(fields: [heating_loop_id], references: [heating_loop_id])
  temperature_reading  TemperatureReading @relation(fields: [temperature_reading_id], references: [temperature_reading_id])

  @@index([heating_loop_id, evaluated_at(sort: Desc)], name: "IX_heating_demands_loop_evaluated_at")
  @@map("heating_demands")
}

// =========================================================
// 21. VALVE EVENTS
// =========================================================
model ValveEvent {
  valve_event_id  BigInt   @id @default(autoincrement())
  heating_loop_id BigInt
  device_id       BigInt
  valve_state     String   @db.VarChar(10)
  reason          String   @db.VarChar(30)
  event_time      DateTime @default(now()) @db.Timestamptz()
  created_at      DateTime @default(now()) @db.Timestamptz()

  heating_loop HeatingLoop @relation(fields: [heating_loop_id], references: [heating_loop_id])
  device       Device      @relation(fields: [device_id], references: [device_id])

  @@index([heating_loop_id, event_time(sort: Desc)], name: "IX_valve_events_loop_event_time")
  @@map("valve_events")
}

// =========================================================
// 22. BOILER CONTROLLER
// =========================================================
model BoilerController {
  boiler_controller_id BigInt   @id @default(autoincrement())
  home_id              BigInt   @unique
  relay_device_id      BigInt   @unique
  controller_name      String   @db.VarChar(100)
  is_active            Boolean  @default(true)
  created_at           DateTime @default(now()) @db.Timestamptz()
  updated_at           DateTime @default(now()) @updatedAt @db.Timestamptz()

  home         Home   @relation(fields: [home_id], references: [home_id])
  relay_device Device @relation(fields: [relay_device_id], references: [device_id])

  boiler_events BoilerEvent[]

  @@map("boiler_controller")
}

// =========================================================
// 23. BOILER EVENTS
// =========================================================
model BoilerEvent {
  boiler_event_id      BigInt   @id @default(autoincrement())
  boiler_controller_id BigInt
  trigger_loop_id      BigInt?
  event_type           String   @db.VarChar(15)
  reason               String   @db.VarChar(40)
  event_time           DateTime @default(now()) @db.Timestamptz()
  created_at           DateTime @default(now()) @db.Timestamptz()

  boiler_controller BoilerController @relation(fields: [boiler_controller_id], references: [boiler_controller_id])
  trigger_loop      HeatingLoop?     @relation(fields: [trigger_loop_id], references: [heating_loop_id])

  @@index([event_time(sort: Desc)], name: "IX_boiler_events_event_time")
  @@map("boiler_events")
}

// =========================================================
// 24. DEVICE STATUS LOG
// =========================================================
model DeviceStatusLog {
  device_status_log_id BigInt   @id @default(autoincrement())
  device_id            BigInt
  status_type          String   @db.VarChar(20)
  status_time          DateTime @default(now()) @db.Timestamptz()
  details_json         Json?
  created_at           DateTime @default(now()) @db.Timestamptz()

  device Device @relation(fields: [device_id], references: [device_id])

  @@index([device_id, status_time(sort: Desc)], name: "IX_device_status_log_device_time")
  @@map("device_status_log")
}
